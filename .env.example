# Restaurant Billing System - Environment Variables
# Copy this to .env and fill in your actual values
# NEVER commit .env to GitHub!

# Flask
FLASK_ENV=production
FLASK_DEBUG=False
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database
DATABASE_URL=postgresql://user:password@localhost/restaurant_billing_web

# Security
ENCRYPTION_KEY=fernet-key-here

# Stripe (if using payments)
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_live_your_stripe_public_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
ENABLE_PAYMENTS=True

# License Server
LICENSE_SERVER_API=https://web-production-99f80.up.railway.app/api/verify-license

# QR Generation
ENABLE_QR_GENERATION=True

# Logging
LOG_LEVEL=INFO

# Redis (for rate limiting)
REDIS_URL=redis://localhost:6379
